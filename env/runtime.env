# Shared runtime values for local 3-container stack
TZ=America/Toronto
LOG_LEVEL=info
ROS_DOMAIN_ID=42

# FANUC interface launch args
FANUC_USE_SIMULATION=false
FANUC_IP=192.168.0.10
FANUC_URDF_FILE_NAME=fanuc200ic5l_w_sg2.urdf

# Tomato pipeline camera config
REALSENSE_SERIAL_ID_D405=218622279985
D405_TF_FRAME=tool_d405_camera_origin

# Tomato pipeline run artifact layout (root/date/trial)
PIPELINE_DATA_ROOT=/data
PIPELINE_TRIAL_NUM=1
PIPELINE_INTERACTIVE=true
